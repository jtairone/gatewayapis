<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gateway API JTI | Hub de Serviços</title>
    <link rel="shortcut icon" type="image/png" href="/img/logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --bg-dark: #0a0c10;
            --card-bg: #111315;
            --border-color: #1e2128;
            --accent-blue: #3b82f6;
            --accent-purple: #8b5cf6;
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --accent-yellow: #f59e0b;
            --text-primary: #e5e7eb;
            --text-secondary: #9ca3af;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        
        .navbar {
            background: rgba(17, 19, 21, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
        }
        
        .hero-section {
            text-align: center;
            padding: 3rem 0 2rem;
        }
        
        .gif-container {
            width: 100px;
            height: 100px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse 2s ease-in-out infinite;
        }
        
        .gif-container img {
            /* width: 60px; */
            height: 180px;
            filter: brightness(0) invert(1);
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.9; }
        }
        
        /* Status Card - Performance Global */
        .status-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 1rem;
            padding: 1.5rem;
            transition: all 0.3s ease;
            margin-bottom: 2rem;
        }
        
        /* Stats Container - Horizontal layout */
        .stats-container {
            display: flex;
            flex-direction: row;
            justify-content: space-around;
            gap: 1.5rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }
        
        .stat-item {
            text-align: center;
            padding: 1rem 1.5rem;
            background: rgba(59, 130, 246, 0.05);
            border-radius: 0.75rem;
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
            flex: 1;
            min-width: 150px;
        }
        
        .stat-item:hover {
            border-color: var(--accent-blue);
            transform: translateY(-2px);
        }
        
        .stat-value {
            font-size: 2rem;
            font-weight: bold;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .stat-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-top: 0.5rem;
        }
        
        /* Service Grid - 3 cards por linha */
        .service-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        /* Responsivo: tablets */
        @media (max-width: 992px) {
            .service-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        /* Responsivo: mobile */
        @media (max-width: 768px) {
            .service-grid {
                grid-template-columns: 1fr;
            }
            
            .stats-container {
                flex-direction: column;
            }
            
            .stat-item {
                min-width: auto;
            }
        }
        
        /* API Cards */
        .api-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 1rem;
            padding: 1.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .api-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        
        .api-card:hover::before {
            transform: scaleX(1);
        }
        
        .api-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent-blue);
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.1);
        }
        
        .api-card i {
            font-size: 2rem;
            margin-bottom: 1rem;
        }
        
        .status-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.75rem;
            border-radius: 0.5rem;
            background: rgba(16, 185, 129, 0.1);
            color: var(--accent-green);
            font-weight: 500;
        }
        
        .status-badge.offline {
            background: rgba(239, 68, 68, 0.1);
            color: var(--accent-red);
        }
        
        .status-badge.degraded {
            background: rgba(245, 158, 11, 0.1);
            color: var(--accent-yellow);
        }
        
        .status-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent-green);
            margin-right: 0.5rem;
            animation: blink 1.5s infinite;
        }
        
        .status-dot.offline {
            background: var(--accent-red);
            animation: none;
        }
        
        .status-dot.degraded {
            background: var(--accent-yellow);
            animation: pulse 1s infinite;
        }
        
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .endpoint-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        
        .endpoint-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.75rem;
            background: rgba(59, 130, 246, 0.05);
            border-radius: 0.5rem;
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
        }
        
        .endpoint-item:hover {
            border-color: var(--accent-blue);
            background: rgba(59, 130, 246, 0.1);
        }
        
        .method {
            font-family: 'Courier New', monospace;
            font-weight: bold;
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            background: rgba(59, 130, 246, 0.2);
            color: var(--accent-blue);
            font-size: 0.75rem;
            min-width: 50px;
            text-align: center;
        }
        
        .method.get { background: rgba(16, 185, 129, 0.2); color: var(--accent-green); }
        .method.post { background: rgba(59, 130, 246, 0.2); color: var(--accent-blue); }
        .method.put { background: rgba(245, 158, 11, 0.2); color: var(--accent-yellow); }
        .method.delete { background: rgba(239, 68, 68, 0.2); color: var(--accent-red); }
        .method.any { background: rgba(139, 92, 246, 0.2); color: var(--accent-purple); }
        
        .path {
            font-family: 'Courier New', monospace;
            color: var(--text-primary);
            font-size: 0.875rem;
        }
        
        .footer {
            margin-top: 3rem;
            padding: 2rem;
            border-top: 1px solid var(--border-color);
            background: var(--card-bg);
        }
        
        .table {
            color: var(--text-primary);
        }
        
        .table td {
            padding: 0.5rem 0;
            border: none;
        }
        
        .badge {
            font-weight: normal;
            padding: 0.25rem 0.75rem;
        }
        
        .loading {
            text-align: center;
            padding: 2rem;
            color: var(--text-secondary);
        }
        
        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid var(--border-color);
            border-top-color: var(--accent-blue);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 1rem;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .section-title {
            margin-bottom: 1.5rem;
            font-size: 1.5rem;
            font-weight: 600;
        }
        
        .section-title i {
            margin-right: 0.75rem;
            color: var(--accent-blue);
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-hdd-stack-fill me-2 text-info"></i>
                <span class="fw-bold">Gateway JTI</span>
            </a>
            <div class="ms-auto d-none d-md-block">
                <span class="badge bg-success-subtle text-success border border-success-subtle" id="gateway-status">
                    <i class="bi bi-check-circle-fill"></i> Carregando...
                </span>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="hero-section">
            <div class="gif-container">
                <img src="/img/apiGif.gif" alt="API Operação">
            </div>
            <h1 class="display-5 fw-bold">Ecosistema de APIs</h1>
            <p class="text-secondary">Roteamento inteligente e gestão centralizada de microsserviços.</p>
        </div>

        <!-- Performance Global - Cards horizontais -->
        <div class="status-card">
            <h5 class="mb-4">
                <i class="bi bi-graph-up me-2"></i>Performance Global
            </h5>
            <div class="stats-container">
                <div class="stat-item">
                    <div class="stat-value" id="availability">--%</div>
                    <div class="stat-label">Disponibilidade</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="active-services">--</div>
                    <div class="stat-label">Nodes Ativos</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="total-requests">0</div>
                    <div class="stat-label">Requisições Totais</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="average-latency">-- ms</div>
                    <div class="stat-label">Latência Média</div>
                </div>
            </div>
        </div>

        <!-- Serviços Disponíveis - Grid 3 colunas -->
        <div class="section-title">
            <i class="bi bi-grid-3x3-gap-fill"></i>
            Serviços Disponíveis
            <span class="badge bg-secondary ms-2" id="total-services"><%= apiCount %></span>
        </div>
        <div class="service-grid" id="services-grid">
            <div class="loading">
                <div class="spinner"></div>
                <p>Carregando serviços...</p>
            </div>
        </div>

        <!-- Informações adicionais em 2 colunas -->
        <div class="row">
            <div class="col-lg-7">
                <div class="status-card h-100">
                    <h5 class="mb-4">
                        <i class="bi bi-diagram-3 me-2"></i>Roteamento de Endpoints
                    </h5>
                    <div class="endpoint-list" id="endpoint-list">
                        <div class="loading small">Carregando rotas...</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="status-card h-100">
                    <h5 class="mb-4">
                        <i class="bi bi-info-circle me-2"></i>Propriedades do Node
                    </h5>
                    <table class="table table-dark table-borderless small m-0">
                        <tbody id="node-properties">
                            <tr><td class="text-secondary">Carregando...</td><td class="text-end">--</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="container text-center">
            <p>© <span id="year"></span> JTI Tecnologia | <span id="gateway-version">v1.0.0</span></p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <span class="small"><i class="bi bi-shield-check"></i> Firewall Ativo</span>
                <span class="small"><i class="bi bi-cpu"></i> Load Balancer</span>
                <span class="small"><i class="bi bi-arrow-repeat"></i> Auto-refresh <span id="interval"></span>s</span>
                <span class="small"><i class="bi bi-cloud-check"></i> Cloudflare Proxy</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/scripts.js"></script>
</body>
</html>