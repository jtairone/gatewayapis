<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gateway API JTI | Hub de Serviços</title>
    <link rel="shortcut icon" type="image/png" href="/img/logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-hdd-stack-fill me-2 text-info"></i>
                <span class="fw-bold">Gateway JTI</span>
            </a>
            <div class="ms-auto d-none d-md-block">
                <span class="badge bg-success-subtle text-success border border-success-subtle">
                    Sistemas Online
                </span>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="hero-section">
            <div class="gif-container">
                <img src="/img/apiGif.gif" alt="API Operação">
            </div>
            <h1 class="display-5 fw-bold">Ecosistema de APIs</h1>
            <p class="text-secondary">Roteamento inteligente e gestão centralizada de microsserviços.</p>
        </div>

        <div class="status-card mb-5">
            <h5 class="text-secondary mb-4"><i class="bi bi-graph-up me-2"></i>Performance Global</h5>
            <div class="stats-container">
                <div class="stat-item">
                    <div class="stat-value">99.9%</div>
                    <div class="stat-label">Disponibilidade</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="active-services">3</div>
                    <div class="stat-label">Nodes Ativos</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="total-requests">0</div>
                    <div class="stat-label">Requisições/Hora</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="average-latency">-- ms</div>
                    <div class="stat-label">Latência Média</div>
                </div>
            </div>
        </div>

        <h3 class="mb-4">Serviços Disponíveis</h3>
        <div class="service-grid">
             <div class="api-card cliente" onclick="window.location.href='/api/cliente'">
                <div class="d-flex justify-content-between align-items-start">
                    <i class="bi bi-people-fill"></i>
                    <span class="status-badge"><span class="status-dot"></span> Online</span>
                </div>
                <h4>API Cliente</h4>
                <p class="text-secondary small">Gestão de cadastro e perfis de clientes finais.</p>
                <code class="text-info">/api/cliente</code>
                <div class="mt-2 small text-secondary">
                    <i class="bi bi-arrow-repeat"></i> <span id="cliente-requests">0</span> requisições
                </div>
            </div>

            <div class="api-card admin" onclick="window.location.href='/api/admin'">
                <div class="d-flex justify-content-between align-items-start">
                    <i class="bi bi-shield-lock-fill"></i>
                    <span class="status-badge"><span class="status-dot"></span> Online</span>
                </div>
                <h4>API Admin</h4>
                <p class="text-secondary small">Núcleo administrativo e permissões de sistema.</p>
                <code class="text-info" style="color: var(--accent-purple) !important;">/api/admin</code>
                <div class="mt-2 small text-secondary">
                    <i class="bi bi-arrow-repeat"></i> <span id="admin-requests">0</span> requisições
                </div>
            </div>

            <div class="api-card motorista" onclick="window.location.href='/api/appmotorista'">
                <div class="d-flex justify-content-between align-items-start">
                    <i class="bi bi-truck-front-fill"></i>
                    <span class="status-badge"><span class="status-dot"></span> Online</span>
                </div>
                <h4>API Motorista</h4>
                <p class="text-secondary small">Roteamento e logística para o app mobile.</p>
                <code class="text-info" style="color: var(--accent-green) !important;">/api/appmotorista</code>
                <div class="mt-2 small text-secondary">
                    <i class="bi bi-arrow-repeat"></i> <span id="appmotorista-requests">0</span> requisições
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-7">
                <div class="status-card h-100">
                    <h5 class="mb-4">Roteamento de Endpoints</h5>
                    <div class="endpoint-list">
                        <div class="endpoint-item">
                            <span class="method">GET</span> <span class="path">/health</span>
                            <span class="ms-auto badge bg-dark text-secondary">Monitoramento</span>
                        </div>
                        <div class="endpoint-item">
                            <span class="method">ANY</span> <span class="path">/api/cliente/*</span>
                            <span class="ms-auto badge bg-dark text-secondary">Proxy Cliente</span>
                        </div>
                        <div class="endpoint-item">
                            <span class="method">ANY</span> <span class="path">/api/admin/*</span>
                            <span class="ms-auto badge bg-dark text-secondary">Proxy Admin</span>
                        </div>
                        <div class="endpoint-item">
                            <span class="method">ANY</span> <span class="path">/api/appmotorista/*</span>
                            <span class="ms-auto badge bg-dark text-secondary">Proxy Driver</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="status-card h-100">
                    <h5 class="mb-4">Propriedades do Node</h5>
                    <table class="table table-dark table-borderless small m-0">
                        <tr>
                            <td class="text-secondary">Gateway Port:</td>
                            <td class="text-end fw-bold"><%= porta || '2096' %></td>
                        </tr>
                        <tr>
                            <td class="text-secondary">Protocol:</td>
                            <td class="text-end text-success fw-bold">HTTPS (SSL)</td>
                        </tr>
                        <tr>
                            <td class="text-secondary">Public Host:</td>
                            <td class="text-end text-info"><%= publichost || 'api.jti.com.br' %></td>
                        </tr>
                        <tr>
                            <td class="text-secondary">Server Time:</td>
                            <td class="text-end" id="current-time">--:--:--</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="container text-center">
            <p>© <span id="year"></span> JTI Tecnologia | v1.0.0-stable</p>
            <div class="d-flex justify-content-center gap-3">
                <span class="small"><i class="bi bi-shield-check"></i> Firewall Ativo</span>
                <span class="small"><i class="bi bi-cpu"></i> Load Balancer</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="js/scripts.js"></script>
</body>
</html>