<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gateway API JTI | Roteamento Inteligente</title>
    <link rel="shortcut icon" type="image/png" href="/img/logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-hdd-stack-fill"></i>
                Gateway API JTI
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/health">
                            <i class="bi bi-heart-pulse-fill"></i> Health Check
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/api/cliente">
                            <i class="bi bi-people-fill"></i> API Cliente
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/api/admin">
                            <i class="bi bi-people-fill"></i> API Admin
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/api/appmotorista">
                            <i class="bi bi-people-fill"></i> API App Motorista
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-container">
        <div class="container">
            <!-- Hero Section -->
            <div class="hero-section">
                <div class="gif-container">
                    <img src="/img/apiGif.gif" alt="Gateway API em operação">
                </div>
                <h1>Gateway de APIs</h1>
                <p class="lead">Roteamento inteligente e gerenciamento centralizado de microsserviços</p>
                
                <!-- Status Card -->
                <div class="status-card">
                    <h3><i class="bi bi-check-circle-fill me-2"></i>Status do Sistema</h3>
                    <div class="stats-container">
                        <div class="stat-item">
                            <div class="stat-value">99.9%</div>
                            <div class="stat-label">Uptime</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value"><span id="active-services">1</span></div>
                            <div class="stat-label">Serviços Ativos</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value"><span id="total-requests">0</span></div>
                            <div class="stat-label">Requisições</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value"><span id="cliente-requests">0</span></div>
                            <div class="stat-label">API Cliente</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value"><span id="admin-requests">0</span></div>
                            <div class="stat-label">API Admin</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value"><span id="motorista-requests">0</span></div>
                            <div class="stat-label">API App Motorista</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Services Grid -->
            <h2 class="text-center mb-4" style="color: #4fc3f7;">Serviços Disponíveis</h2>
            <div class="service-grid">
                <!-- API Cliente -->
                <div class="service-card-cliente" onclick="window.location.href='/api/cliente'">
                    <i class="bi bi-people-fill"></i>
                    <h4>API Cliente</h4>
                    <p class="text-secondary">Gerenciamento de clientes</p>
                    <span class="badge">
                        <span class="status-badge status-online"></span> Online
                    </span>
                </div>

                <!-- API Admin (comentada) --> 
                <div class="service-card-admin" onclick="window.location.href='/api/admin'">
                    <i class="bi bi-shield-lock-fill"></i>
                    <h4>API Admin</h4>
                    <p class="text-secondary">Administração do sistema</p>
                    <span class="badge">
                        <span class="status-badge status-online"></span> Online
                    </span>
                </div>
                
                <div class="service-card-motorista" onclick="window.location.href='/api/appmotorista'">
                    <i class="bi bi-truck-front-fill"></i>
                    <h4>API Motorista</h4>
                    <p class="text-secondary">Gestão de motoristas</p>
                    <span class="badge">
                        <span class="status-badge status-online"></span> Online
                    </span>
                </div>
               
            </div>

            <!-- Endpoints Disponíveis -->
            <div class="status-card mt-4">
                <h3><i class="bi bi-link-45deg me-2"></i>Endpoints Públicos</h3>
                <ul class="endpoint-list">
                    <li>
                        <span class="method">GET</span>
                        <span class="path">/health</span>
                        <span class="text-success ms-auto">Health Check</span>
                    </li>
                    <li>
                        <span class="method">GET</span>
                        <span class="path">/api/cliente</span>
                        <span class="text-success ms-auto">API Cliente</span>
                    </li>
                    <li>
                        <span class="method">GET</span>
                        <span class="path">/api/admin</span>
                        <span class="text-success ms-auto">API Admin</span>
                    </li>
                    <li>
                        <span class="method">GET</span>
                        <span class="path">/api/appmotorista</span>
                        <span class="text-success ms-auto">API App Motorista</span>
                    </li>
                    <li>
                        <span class="method">GET</span>
                        <span class="path">/</span>
                        <span class="text-success ms-auto">Gateway Dashboard</span>
                    </li>
                </ul>
            </div>

            <!-- Informações Técnicas -->
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="status-card">
                        <h3><i class="bi bi-cpu me-2"></i>Configuração</h3>
                        <table class="table table-dark table-borderless">
                            <tr>
                                <td>Gateway:</td>
                                <td><strong class="gateway"></strong></td>
                            </tr>
                            <tr>
                                <td>Protocolo:</td>
                                <td><strong>HTTPS</strong></td>
                            </tr>
                            <tr>
                                <td>Porta:</td>
                                <td><strong><%= porta || '2096' %></strong></td>
                            </tr>
                            <tr>
                                <td>API Cliente:</td>
                                <td><strong><%= apiClienteUrl %></strong></td>
                            </tr>
                            <tr>
                                <td>API Admin:</td>
                                <td><strong><%= apiAdminUrl %></strong></td>
                            </tr>
                            <tr>
                                <td>API App Motorista:</td>
                                <td><strong><%= apiAppMotoristaUrl %></strong></td>
                            </tr>
                        </table>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="status-card">
                        <h3><i class="bi bi-clock-history me-2"></i>Informações</h3>
                        <table class="table table-dark table-borderless">
                            <tr>
                                <td>Data:</td>
                                <td><strong id="current-date"></strong></td>
                            </tr>
                            <tr>
                                <td>Hora:</td>
                                <td><strong id="current-time"></strong></td>
                            </tr>
                            <tr>
                                <td>Status:</td>
                                <td><span class="badge bg-success">Operacional</span></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container text-center">
            <p>
                <i class="bi bi-c-circle me-1"></i>
                <span id="year"></span> Tecnologia JTI - Gateway API v1.0
                <i class="bi bi-shield-check ms-2"></i>
            </p>
            <p class="small">
                <i class="bi bi-hdd-network me-1"></i> Roteamento inteligente · 
                <i class="bi bi-shield-lock me-1"></i> SSL/TLS · 
                <i class="bi bi-arrow-repeat me-1"></i> Load Balancing
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/scripts.js"></script>
</body>
</html>